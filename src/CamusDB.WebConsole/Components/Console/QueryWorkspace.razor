@inject CamusSessionService Session
@inject QueryExecutionService Queries
@inject ConsolePreferencesService Prefs
@inject ISnackbar Snackbar
@implements IDisposable

<div class="query-workspace">
    <div class="query-tabs">
        @foreach (QueryTab tab in _tabs)
        {
            <div class="query-tab @(tab.Id == _activeId ? "active" : null)"
                 @onclick="() => ActivateAsync(tab.Id)"
                 role="tab"
                 aria-selected="@(tab.Id == _activeId)">
                <span class="query-tab-title">@tab.Title</span>
                @if (_tabs.Count > 1)
                {
                    <button type="button"
                            class="query-tab-close"
                            title="Close tab"
                            @onclick="() => CloseTabAsync(tab.Id)"
                            @onclick:stopPropagation="true">
                        ×
                    </button>
                }
            </div>
        }
        <button type="button"
                class="query-tab-add"
                title="New query tab"
                @onclick="AddTabAsync">
            +
        </button>
    </div>

    <div class="query-split">
        <div class="query-editor-pane" style="@($"height:{_editorHeight}px")">
            <div class="query-editor-toolbar">
                @if (_running)
                {
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Stop"
                               OnClick="CancelRun">
                        Stop
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           Class="run-btn"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           Disabled="_running || !Session.IsConnected"
                           OnClick="RunAsync">
                    Run query
                </MudButton>
            </div>
            @if (ActiveTab is not null)
            {
                <div style="flex:1; min-height:0;" @key="ActiveTab.Id">
                    <QueryEditor @ref="_editor"
                                 EditorId="@($"sql-editor-{ActiveTab.Id}")"
                                 Value="@ActiveTab.Sql"
                                 ValueChanged="OnSqlChangedAsync"
                                 OnRunRequested="RunAsync" />
                </div>
            }
        </div>

        <div class="split-handle"
             @onpointerdown="OnSplitPointerDown"></div>

        @if (_splitting)
        {
            <div class="split-overlay"
                 @onpointermove="OnSplitPointerMove"
                 @onpointerup="OnSplitPointerUp"
                 @onpointercancel="OnSplitPointerUp"></div>
        }

        <div class="results-pane" @key="@($"results-{_activeId}")">
            <ExecutionStatusBar Result="ActiveTab?.LastResult" />
            <ResultsGrid Result="ActiveTab?.LastResult"
                         TableContext="ActiveTab?.DataContext"
                         OnDataChanged="RefreshActiveDataAsync" />
        </div>
    </div>
</div>

@code {
    private readonly List<QueryTab> _tabs = [];
    private string _activeId = "";
    private QueryEditor? _editor;
    private bool _running;
    private CancellationTokenSource? _cts;
    private int _editorHeight = 220;
    private bool _splitting;
    private double _splitStartY;
    private int _splitStartHeight;
    private int _tabSeq = 1;
    private bool _hydrated;

    private QueryTab? ActiveTab => _tabs.FirstOrDefault(t => t.Id == _activeId);

    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hydrated)
            return;

        _hydrated = true;

        try
        {
            await Prefs.EnsureLoadedAsync();
            ConsoleUiPreferences prefs = Prefs.Current;

            if (prefs.EditorHeight is int height)
                _editorHeight = Math.Clamp(height, 120, 700);

            if (prefs.Tabs is { Count: > 0 })
            {
                _tabs.Clear();
                foreach (PersistedQueryTab saved in prefs.Tabs)
                {
                    if (string.IsNullOrWhiteSpace(saved.Id))
                        continue;

                    _tabs.Add(new QueryTab
                    {
                        Id = saved.Id,
                        Title = string.IsNullOrWhiteSpace(saved.Title) ? "SQL" : saved.Title,
                        Sql = saved.Sql ?? "",
                    });
                }

                if (_tabs.Count > 0)
                {
                    _tabSeq = prefs.TabSeq > 0
                        ? prefs.TabSeq
                        : Math.Max(1, _tabs.Count + 1);

                    _activeId = _tabs.Any(t => t.Id == prefs.ActiveTabId)
                        ? prefs.ActiveTabId!
                        : _tabs[0].Id;
                }
            }
        }
        catch
        {
            // Fall back to a default tab below.
        }

        if (_tabs.Count == 0)
            AddTabCore(selectSql: "SELECT 1", persist: false);

        StateHasChanged();
    }

    public async Task InsertSqlAsync(string sql)
    {
        await PersistActiveEditorAsync();

        if (ActiveTab is null)
            AddTabCore(selectSql: sql);
        else
        {
            ActiveTab.Sql = sql;
            ActiveTab.Title = TruncateTitle(sql);
            ActiveTab.DataContext = null;
            await PersistTabsAsync();
        }

        StateHasChanged();
    }

    public async Task OpenTableDataAsync(TableDataContext context)
    {
        await PersistActiveEditorAsync();

        int limit = Math.Max(1, Session.MaxRows);
        string sql = SqlBuilder.BuildSelectAll(context.Table, limit);

        if (ActiveTab is null)
            AddTabCore(selectSql: sql);

        if (ActiveTab is not null)
        {
            ActiveTab.Sql = sql;
            ActiveTab.Title = $"data:{context.Table}";
            ActiveTab.DataContext = context;
            ActiveTab.LastResult = null;
            await PersistTabsAsync();
        }

        StateHasChanged();
        await RunAsync();
    }

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    private async Task OnSqlChangedAsync(string sql)
    {
        if (ActiveTab is null)
            return;

        ActiveTab.Sql = sql;
        await PersistTabsAsync(debounce: true);
    }

    private async Task AddTabAsync()
    {
        await PersistActiveEditorAsync();
        AddTabCore(selectSql: "");
    }

    private void AddTabCore(string selectSql, bool persist = true)
    {
        var tab = new QueryTab
        {
            Id = Guid.NewGuid().ToString("N"),
            Title = string.IsNullOrWhiteSpace(selectSql) ? $"SQL {_tabSeq}" : TruncateTitle(selectSql),
            Sql = selectSql,
        };
        _tabSeq++;
        _tabs.Add(tab);
        _activeId = tab.Id;

        if (persist)
            _ = PersistTabsAsync();
    }

    private async Task ActivateAsync(string id)
    {
        if (id == _activeId)
            return;

        await PersistActiveEditorAsync();
        _activeId = id;
        await PersistTabsAsync();
    }

    private async Task CloseTabAsync(string id)
    {
        if (_tabs.Count <= 1)
            return;

        if (id == _activeId)
            await PersistActiveEditorAsync();

        int index = _tabs.FindIndex(t => t.Id == id);
        if (index < 0)
            return;

        _tabs.RemoveAt(index);
        if (_activeId == id)
            _activeId = _tabs[Math.Clamp(index, 0, _tabs.Count - 1)].Id;

        await PersistTabsAsync();
    }

    private async Task PersistActiveEditorAsync()
    {
        if (_editor is null || ActiveTab is null)
            return;

        try
        {
            await _editor.SyncValueAsync();
        }
        catch
        {
            // Editor may already be disposed while switching tabs.
        }
    }

    private Task PersistTabsAsync(bool debounce = false)
    {
        var snapshot = _tabs
            .Select(t => new PersistedQueryTab
            {
                Id = t.Id,
                Title = t.Title,
                Sql = t.Sql ?? "",
            })
            .ToList();

        return Prefs.SaveTabsAsync(snapshot, _activeId, _tabSeq, debounce);
    }

    private async Task RunAsync()
    {
        if (ActiveTab is null || _running)
            return;

        if (!Session.IsConnected)
        {
            Snackbar.Add("Not connected. Open Configure to connect.", Severity.Warning);
            return;
        }

        await PersistActiveEditorAsync();

        string sql = ActiveTab.Sql?.Trim() ?? "";
        if (sql.Length == 0)
        {
            Snackbar.Add("SQL is empty.", Severity.Warning);
            return;
        }

        if (ActiveTab.DataContext is null)
            ActiveTab.Title = TruncateTitle(sql);

        await PersistTabsAsync();

        _running = true;
        _cts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            QueryResultModel result = await Queries.ExecuteAsync(sql, _cts.Token);
            ActiveTab.LastResult = result;
            if (!result.Success)
                Snackbar.Add(result.ErrorMessage ?? "Query failed", Severity.Error);
        }
        finally
        {
            _running = false;
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private Task RefreshActiveDataAsync() => RunAsync();

    private void CancelRun() => _cts?.Cancel();

    private void OnSplitPointerDown(PointerEventArgs e)
    {
        _splitting = true;
        _splitStartY = e.ClientY;
        _splitStartHeight = _editorHeight;
    }

    private void OnSplitPointerMove(PointerEventArgs e)
    {
        if (!_splitting)
            return;

        int next = _splitStartHeight + (int)(e.ClientY - _splitStartY);
        int clamped = Math.Clamp(next, 120, 700);
        if (clamped != _editorHeight)
            _editorHeight = clamped;
    }

    private void OnSplitPointerUp(PointerEventArgs e)
    {
        _splitting = false;
        _ = Prefs.SetEditorHeightAsync(_editorHeight);
    }

    private static string TruncateTitle(string sql)
    {
        string oneLine = sql.Replace('\n', ' ').Replace('\r', ' ').Trim();
        if (oneLine.Length == 0)
            return "SQL";
        return oneLine.Length <= 28 ? oneLine : oneLine[..28] + "…";
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
        _cts?.Cancel();
        _cts?.Dispose();

        if (_hydrated && _tabs.Count > 0)
        {
            // Best-effort flush of the latest SQL before the circuit tears down.
            _ = PersistTabsAsync();
        }
    }

    private sealed class QueryTab
    {
        public required string Id { get; init; }
        public string Title { get; set; } = "SQL";
        public string Sql { get; set; } = "";
        public QueryResultModel? LastResult { get; set; }
        public TableDataContext? DataContext { get; set; }
    }
}
