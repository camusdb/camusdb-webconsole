@page "/"
@inject CamusSessionService Session
@inject ConsolePreferencesService Prefs

<PageTitle>CamusDB Web Console</PageTitle>

<div class="console-main" style="flex-direction: row; display: flex; flex: 1; min-height: 0; width: 100%; height: 100%;">
    <SchemaExplorer OnInsertSql="InsertSqlAsync" OnOpenTableData="OpenTableDataAsync" />
    <div class="console-main" style="height: 100%;">
        <QueryWorkspace @ref="_workspace" />
    </div>
</div>

@code {
    private QueryWorkspace? _workspace;
    private bool _triedConnect;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _triedConnect || Session.IsConnected)
            return;

        _triedConnect = true;

        try
        {
            await Prefs.EnsureLoadedAsync();
            if (!string.IsNullOrWhiteSpace(Prefs.Current.Database))
                Session.PreferDatabase(Prefs.Current.Database);
        }
        catch
        {
            // Continue with appsettings defaults.
        }

        try
        {
            await Session.ConnectAsync();
            await Prefs.SetDatabaseAsync(Session.Database);
        }
        catch
        {
            // Footer / Configure show the error; stay on the console.
        }
    }

    private async Task InsertSqlAsync(string sql)
    {
        if (_workspace is not null)
            await _workspace.InsertSqlAsync(sql);
    }

    private async Task OpenTableDataAsync(TableDataContext context)
    {
        if (_workspace is not null)
            await _workspace.OpenTableDataAsync(context);
    }
}
